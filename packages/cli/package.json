    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "conf": "^13.0.1",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  }
}
