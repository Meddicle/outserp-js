{
  "name": "@outserp/cli",
  "version": "1.0.0",
  "description": "Outserp CLI — AI SEO & AEO content platform from your terminal",
  "homepage": "https://outserp.ai/docs/api",
  "type": "module",
  "bin": {
    "outserp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
